# LLM via Gemini API (Google AI Studio)
GOOGLE_API_KEY=
ANSWER_MODEL=gemma-4-31b-it
FAST_MODEL=gemma-4-31b-it

# Embeddings via OpenAI
OPENAI_API_KEY=

# Vector store: "pgvector" (deployed) or "chroma" (local-only)
VECTOR_STORE=chroma
SUPABASE_DB_URL=
CHROMA_PERSIST_DIR=./data/chroma_db

# Optional observability
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=hdb-rag
